@page "/settings"
@implements IAsyncDisposable
@inject INetworkTimeWorkspaceService Workspace
@inject IJSRuntime JSRuntime

<PageTitle>Settings</PageTitle>

@if (_editor is null)
{
    <p class="loading-state">Loading settings from local storage...</p>
}
else
{
    <section class="page-hero compact-hero">
        <div>
            <p class="eyebrow">Settings</p>
            <h1>Sync Preferences</h1>
            <p class="page-lede">This editor persists real settings through the JSON repositories from the core layer and mirrors the structure of the original NetTime options screen.</p>
        </div>
        <div class="hero-actions">
            <button type="button" class="btn btn-light action-button" @onclick="LoadStoredAsync">Reload Stored</button>
            <button type="button" class="btn btn-light action-button" @onclick="LoadDefaults">Use Defaults</button>
        </div>
    </section>

    <EditForm Model="_editor" OnValidSubmit="SaveAsync" OnInvalidSubmit="HandleInvalidSubmit">
        <DataAnnotationsValidator />

        <div class="settings-layout">
            <section class="panel settings-form-shell">
                <div class="panel-header">
                    <div>
                        <h2>Time Servers</h2>
                        <p>Up to five entries, matching the original utility layout.</p>
                    </div>
                    <span class="support-pill">Live persistence</span>
                </div>

                <div class="server-editor">
                    <p class="server-editor-note">Press and drag a row handle to change server priority before saving.</p>
                    <div class="server-editor-head">
                        <span>#</span>
                        <span>Hostname or IP Address</span>
                        <span>Protocol</span>
                        <span>Port</span>
                    </div>

                    @for (var index = 0; index < _editor.ServerCount; index++)
                    {
                        var serverIndex = index;

                        <div class="@GetServerRowClass(serverIndex)" data-server-index="@serverIndex">
                            <div class="server-order-token">
                                <span class="server-slot">@(serverIndex + 1)</span>
                                <span class="server-drag-handle"
                                      onpointerdown="window.myNetworkTimeSettings.beginPointerDrag(event, this)"
                                      title="Drag to reorder"
                                      role="button"
                                      tabindex="0">Drag</span>
                            </div>
                            <InputText class="form-control nt-input"
                                       Value="@GetServerHost(serverIndex)"
                                       ValueChanged="@((string value) => SetServerHost(serverIndex, value))"
                                       ValueExpression="@GetServerHostExpression(serverIndex)" />
                            <InputSelect class="form-select nt-select"
                                         Value="@GetServerProtocol(serverIndex)"
                                         ValueChanged="@((ServerProtocol value) => SetServerProtocol(serverIndex, value))"
                                         ValueExpression="@GetServerProtocolExpression(serverIndex)">
                                @foreach (var protocol in ProtocolOptions)
                                {
                                    <option value="@protocol">@FormatProtocol(protocol)</option>
                                }
                            </InputSelect>
                            <InputNumber class="form-control nt-input nt-port"
                                         Value="@GetServerPort(serverIndex)"
                                         ValueChanged="@((int value) => SetServerPort(serverIndex, value))"
                                         ValueExpression="@GetServerPortExpression(serverIndex)" />
                        </div>
                    }
                </div>


                <ValidationSummary class="settings-validation" />
            </section>

            <section class="panel settings-form-shell">
                <div class="panel-header">
                    <div>
                        <h2>Intervals</h2>
                        <p>Update cadence, retries, and adjustment thresholds.</p>
                    </div>
                </div>

                <div class="editor-grid">
                    <div class="editor-field">
                        <label>Update Interval</label>
                        <div class="split-field">
                            <InputNumber class="form-control nt-input" @bind-Value="_editor.UpdateIntervalValue" />
                            <InputSelect class="form-select nt-select" @bind-Value="_editor.UpdateIntervalUnit">
                                @foreach (var unit in BasicIntervalOptions)
                                {
                                    <option value="@unit">@FormatIntervalUnit(unit)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="editor-field">
                        <label>Retry Interval</label>
                        <div class="split-field">
                            <InputNumber class="form-control nt-input" @bind-Value="_editor.RetryIntervalValue" />
                            <InputSelect class="form-select nt-select" @bind-Value="_editor.RetryIntervalUnit">
                                @foreach (var unit in BasicIntervalOptions)
                                {
                                    <option value="@unit">@FormatIntervalUnit(unit)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="editor-field">
                        <label>Max Free Run</label>
                        <div class="split-field">
                            <InputNumber class="form-control nt-input" @bind-Value="_editor.MaxFreeRunValue" />
                            <InputSelect class="form-select nt-select" @bind-Value="_editor.MaxFreeRunUnit">
                                @foreach (var unit in BasicIntervalOptions)
                                {
                                    <option value="@unit">@FormatIntervalUnit(unit)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="editor-field">
                        <label>Adjustment Threshold</label>
                        <div class="split-field">
                            <InputNumber class="form-control nt-input" @bind-Value="_editor.AdjustmentThresholdValue" />
                            <InputSelect class="form-select nt-select" @bind-Value="_editor.AdjustmentThresholdUnit">
                                @foreach (var unit in ThresholdIntervalOptions)
                                {
                                    <option value="@unit">@FormatIntervalUnit(unit)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="editor-field">
                        <label>Adjustment Mode</label>
                        <InputSelect class="form-select nt-select" @bind-Value="_editor.AdjustmentMode">
                            @foreach (var mode in AdjustmentModes)
                            {
                                <option value="@mode">@FormatAdjustmentMode(mode)</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="editor-field">
                        <label>Logging Level</label>
                        <InputSelect class="form-select nt-select" @bind-Value="_editor.LoggingLevel">
                            @foreach (var level in LoggingLevels)
                            {
                                <option value="@level">@level</option>
                            }
                        </InputSelect>
                    </div>
                </div>
            </section>

            <section class="panel settings-form-shell">
                <div class="panel-header">
                    <div>
                        <h2>Behavior</h2>
                        <p>Operational toggles and update policies.</p>
                    </div>
                </div>

                <div class="toggle-grid">
                    <label class="toggle-field">
                        <InputCheckbox class="form-check-input" @bind-Value="_editor.DemoteServers" />
                        <span class="toggle-copy">
                            <strong>Demote Servers</strong>
                            <span>After repeated failures the server is moved behind healthier entries.</span>
                        </span>
                    </label>

                    <label class="toggle-field">
                        <InputCheckbox class="form-check-input" @bind-Value="_editor.AllowPeersToSync" />
                        <span class="toggle-copy">
                            <strong>Allow Peer Sync</strong>
                            <span>Permit other machines to sync against this device when the platform allows it.</span>
                        </span>
                    </label>

                    <label class="toggle-field">
                        <InputCheckbox class="form-check-input" @bind-Value="_editor.AlwaysProvideTime" />
                        <span class="toggle-copy">
                            <strong>Always Provide Time</strong>
                            <span>Keep serving time even when local drift is outside the recommended window.</span>
                        </span>
                    </label>

                    <label class="toggle-field">
                        <InputCheckbox class="form-check-input" @bind-Value="_editor.ShowTrayIconAtLogin" />
                        <span class="toggle-copy">
                            <strong>Show Tray Icon at Login</strong>
                            <span>Preserves the desktop-oriented utility behavior where applicable.</span>
                        </span>
                    </label>

                    <label class="toggle-field">
                        <InputCheckbox class="form-check-input" @bind-Value="_editor.CollapseToTrayOnMinimize" />
                        <span class="toggle-copy">
                            <strong>Collapse to Tray on Minimize</strong>
                            <span>On Windows, minimizing the app window hides it to the tray instead of the taskbar.</span>
                        </span>
                    </label>

                    <label class="toggle-field">
                        <InputCheckbox class="form-check-input" @bind-Value="_editor.StartAtBoot" />
                        <span class="toggle-copy">
                            <strong>Start at Boot</strong>
                            <span>Boot-time activation is subject to platform capabilities and will be finalized later.</span>
                        </span>
                    </label>
                </div>

                <div class="editor-grid secondary-editor-grid">
                    <div class="editor-field">
                        <label>Demote After Failures</label>
                        <InputNumber class="form-control nt-input" @bind-Value="_editor.DemoteAfterFailures" />
                    </div>

                    <div class="editor-field">
                        <label>Auto Check for Updates</label>
                        <div class="split-field">
                            <InputNumber class="form-control nt-input" @bind-Value="_editor.AutoCheckEveryDays" />
                            <span class="static-token">days</span>
                        </div>
                    </div>
                </div>
            </section>
        </div>
        @if (_statusMessage is not null)
        {
            <p class="success-banner">@_statusMessage</p>
        }

        @if (_errorMessage is not null)
        {
            <p class="error-banner">@_errorMessage</p>
        }
        <div class="form-actions">
            <button type="submit" class="btn btn-primary action-button" disabled="@_isSaving">
                @(_isSaving ? "Saving..." : "Save Settings")
            </button>
            <span class="form-note">Changes are written to local JSON storage and will be picked up by the sync engine on the next refresh.</span>
        </div>
    </EditForm>
}

@code {
    private static readonly ServerProtocol[] ProtocolOptions = Enum.GetValues<ServerProtocol>();
    private static readonly IntervalUnit[] BasicIntervalOptions =
    [
        IntervalUnit.Second,
        IntervalUnit.Minute,
        IntervalUnit.Hour,
        IntervalUnit.Day
    ];
    private static readonly IntervalUnit[] ThresholdIntervalOptions = Enum.GetValues<IntervalUnit>();
    private static readonly TimeAdjustmentMode[] AdjustmentModes = Enum.GetValues<TimeAdjustmentMode>();
    private const string ServerOrderUpdatedMessage = "Server order updated. Save settings to persist the new priority.";
    private static readonly string[] LoggingLevels = ["Minimal", "Normal", "Verbose"];

    private SettingsEditorModel? _editor;
    private bool _isSaving;
    private string? _statusMessage;
    private string? _errorMessage;
    private int? _draggedServerIndex;
    private int? _dropTargetServerIndex;
    private DotNetObjectReference<Settings>? _dotNetReference;

    protected override async Task OnInitializedAsync()
    {
        await LoadStoredAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _dotNetReference = DotNetObjectReference.Create(this);
        await JSRuntime.InvokeVoidAsync("myNetworkTimeSettings.initialize", _dotNetReference);
    }

    private async Task LoadStoredAsync()
    {
        try
        {
            var settings = await Workspace.GetSettingsAsync();
            _editor = SettingsEditorModel.FromSnapshot(settings);
            _statusMessage = "Settings loaded from local storage.";
            _errorMessage = null;
        }
        catch (Exception exception)
        {
            _errorMessage = $"Failed to load settings: {exception.Message}";
        }
    }

    private void LoadDefaults()
    {
        _editor = SettingsEditorModel.FromSnapshot(AppSettingsDefaults.Create());
        _statusMessage = "Default values loaded. Save to persist them.";
        _errorMessage = null;
    }

    private async Task SaveAsync()
    {
        if (_editor is null)
        {
            return;
        }

        _isSaving = true;
        try
        {
            await Workspace.SaveSettingsAsync(_editor.ToSnapshot());
            _statusMessage = $"Settings saved at {DateTime.Now:t}.";
            _errorMessage = null;
            await LoadStoredAsync();
        }
        catch (Exception exception)
        {
            _errorMessage = $"Failed to save settings: {exception.Message}";
            _statusMessage = null;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void HandleInvalidSubmit(EditContext _)
    {
        _statusMessage = null;
        _errorMessage = "Review the validation messages and correct the settings before saving.";
    }

    private void StartServerDrag(int index)
    {
        _draggedServerIndex = index;
        _dropTargetServerIndex = index;
        _statusMessage = null;
        _errorMessage = null;
    }

    private void SetDropTarget(int index)
    {
        if (_draggedServerIndex is null)
        {
            return;
        }

        _dropTargetServerIndex = index;
    }

    private void ClearDropTarget(int index)
    {
        if (_dropTargetServerIndex == index && _draggedServerIndex != index)
        {
            _dropTargetServerIndex = null;
        }
    }

    private void CompleteServerDrop(int index)
    {
        if (_editor is null || _draggedServerIndex is null)
        {
            return;
        }

        var sourceIndex = _draggedServerIndex.Value;
        if (sourceIndex != index)
        {
            _editor.MoveServer(sourceIndex, index);
            _statusMessage = ServerOrderUpdatedMessage;
            _errorMessage = null;
        }

        ClearServerDrag();
    }

    private void ClearServerDrag()
    {
        _draggedServerIndex = null;
        _dropTargetServerIndex = null;
    }

    /// <summary>Starts the WebView-safe server reorder gesture from JavaScript.</summary>
    [JSInvokable]
    public Task StartServerDragFromJsAsync(int index)
    {
        StartServerDrag(index);
        return InvokeAsync(StateHasChanged);
    }

    /// <summary>Updates the current drop target for the WebView-safe server reorder gesture.</summary>
    [JSInvokable]
    public Task SetDropTargetFromJsAsync(int index)
    {
        SetDropTarget(index);
        return InvokeAsync(StateHasChanged);
    }

    /// <summary>Completes the WebView-safe server reorder gesture.</summary>
    [JSInvokable]
    public Task CompleteServerDropFromJsAsync(int index)
    {
        CompleteServerDrop(index);
        return InvokeAsync(StateHasChanged);
    }

    /// <summary>Cancels the WebView-safe server reorder gesture.</summary>
    [JSInvokable]
    public Task ClearServerDragFromJsAsync()
    {
        ClearServerDrag();
        return InvokeAsync(StateHasChanged);
    }

    private string GetServerRowClass(int index)
    {
        var classes = new List<string> { "server-editor-row" };

        if (_draggedServerIndex == index)
        {
            classes.Add("server-editor-row-dragging");
        }

        if (_dropTargetServerIndex == index && _draggedServerIndex != index)
        {
            classes.Add("server-editor-row-drop-target");
        }

        return string.Join(" ", classes);
    }

    private string GetServerHost(int index) => _editor?.GetServerHost(index) ?? string.Empty;

    private void SetServerHost(int index, string? value) => _editor?.SetServerHost(index, value ?? string.Empty);

    private ServerProtocol GetServerProtocol(int index) => _editor?.GetServerProtocol(index) ?? ServerProtocol.Sntp;

    private void SetServerProtocol(int index, ServerProtocol value) => _editor?.SetServerProtocol(index, value);

    private int GetServerPort(int index) => _editor?.GetServerPort(index) ?? 123;

    private void SetServerPort(int index, int value) => _editor?.SetServerPort(index, value);

    private System.Linq.Expressions.Expression<Func<string>> GetServerHostExpression(int index) => index switch
    {
        0 => () => _editor!.Server1Host,
        1 => () => _editor!.Server2Host,
        2 => () => _editor!.Server3Host,
        3 => () => _editor!.Server4Host,
        4 => () => _editor!.Server5Host,
        _ => throw new ArgumentOutOfRangeException(nameof(index))
    };

    private System.Linq.Expressions.Expression<Func<ServerProtocol>> GetServerProtocolExpression(int index) => index switch
    {
        0 => () => _editor!.Server1Protocol,
        1 => () => _editor!.Server2Protocol,
        2 => () => _editor!.Server3Protocol,
        3 => () => _editor!.Server4Protocol,
        4 => () => _editor!.Server5Protocol,
        _ => throw new ArgumentOutOfRangeException(nameof(index))
    };

    private System.Linq.Expressions.Expression<Func<int>> GetServerPortExpression(int index) => index switch
    {
        0 => () => _editor!.Server1Port,
        1 => () => _editor!.Server2Port,
        2 => () => _editor!.Server3Port,
        3 => () => _editor!.Server4Port,
        4 => () => _editor!.Server5Port,
        _ => throw new ArgumentOutOfRangeException(nameof(index))
    };

    private static string FormatProtocol(ServerProtocol protocol) => protocol switch
    {
        ServerProtocol.Sntp => "SNTP",
        ServerProtocol.Rfc868Tcp => "RFC868 (TCP)",
        ServerProtocol.Rfc868Udp => "RFC868 (UDP)",
        _ => "Unknown"
    };

    private static string FormatAdjustmentMode(TimeAdjustmentMode mode) => mode switch
    {
        TimeAdjustmentMode.AdjustSystemTime => "Adjust System Time",
        TimeAdjustmentMode.DoNotUpdateTime => "Do Not Update Time",
        TimeAdjustmentMode.AskUser => "Ask User",
        _ => "Unknown"
    };

    private static string FormatIntervalUnit(IntervalUnit unit) => unit switch
    {
        IntervalUnit.Second => "seconds",
        IntervalUnit.Minute => "minutes",
        IntervalUnit.Hour => "hours",
        IntervalUnit.Day => "days",
        IntervalUnit.Week => "weeks",
        IntervalUnit.Year => "years",
        _ => "units"
    };

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("myNetworkTimeSettings.dispose");
        }
        catch (JSDisconnectedException)
        {
        }

        _dotNetReference?.Dispose();
    }
}
