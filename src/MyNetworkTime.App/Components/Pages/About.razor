@page "/about"

<PageTitle>About</PageTitle>

<section class="page-hero compact-hero">
    <div>
        <p class="eyebrow">About</p>
        <h1>Project Roadmap</h1>
        <p class="page-lede">My Network Time is being built as a .NET 10 MAUI Blazor Hybrid app with a shared core and platform-specific sync capabilities.</p>
    </div>
</section>

<section class="panel-grid">
    <article class="panel">
        <div class="panel-header">
            <div>
                <h2>Platforms</h2>
                <p>Shared shell today, native integrations next.</p>
            </div>
        </div>
        <ul class="stack-list">
            <li><strong>Windows:</strong> target platform for real system time synchronization.</li>
            <li><strong>Android:</strong> monitoring, diagnostics, retries, and settings guidance.</li>
            <li><strong>iOS:</strong> monitoring, diagnostics, and system settings guidance.</li>
        </ul>
    </article>

    <article class="panel">
        <div class="panel-header">
            <div>
                <h2>Stage Flow</h2>
                <p>Each stage lives in its own git branch and merges into main only after approval.</p>
            </div>
        </div>
        <ul class="stack-list">
            <li><strong>Stage 1:</strong> bootstrap solution, shell, routing, and design-time data.</li>
            <li><strong>Stage 2:</strong> protocols, settings persistence, orchestration, and tests.</li>
            <li><strong>Stage 3:</strong> production UI for dashboard, settings, and log viewer.</li>
            <li><strong>Stage 4:</strong> platform sync behavior and capability-aware native actions.</li>
            <li><strong>Stage 5:</strong> hardening, branding, and release readiness.</li>
        </ul>
    </article>
</section>
