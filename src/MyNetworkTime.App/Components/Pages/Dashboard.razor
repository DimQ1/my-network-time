@page "/"
@implements IAsyncDisposable
@inject INetworkTimeWorkspaceService Workspace
@inject DashboardRefreshNotifier DashboardRefreshNotifier
@inject TimeProvider TimeProvider

<PageTitle>Dashboard</PageTitle>

@if (_snapshot is null)
{
    <p class="loading-state">Loading bootstrap workspace...</p>
}
else
{
    <section class="page-hero">
        <div>
            <p class="eyebrow">Dashboard</p>
            <h1>Network Time Status</h1>
            <p class="page-lede">A utility-first dashboard inspired by the original desktop tool, now backed by real sync orchestration, platform-aware actions, and scheduled refresh while the app is active.</p>
        </div>
        <div class="hero-actions">
            <button type="button" class="btn btn-primary action-button" disabled="@_isRefreshing" @onclick="ReloadAsync">
                @(_isRefreshing ? "Syncing..." : "Update Now")
            </button>
            @if (_snapshot.CanAdjustSystemTimeFromDashboard)
            {
                <button type="button" class="btn btn-light action-button" disabled="@_isApplyingAdjustment" @onclick="AdjustSystemTimeAsync">
                    @(_isApplyingAdjustment ? "Applying..." : _snapshot.AdjustActionLabel)
                </button>
            }
            @if (_snapshot.Platform.CanOpenSystemTimeSettings)
            {
                <button type="button" class="btn btn-light action-button" disabled="@_isOpeningSettings" @onclick="OpenSystemTimeSettingsAsync">
                    @(_isOpeningSettings ? "Opening..." : _snapshot.Platform.SettingsActionLabel)
                </button>
            }
            <NavLink class="btn btn-light action-button" href="settings">Settings</NavLink>
        </div>
    </section>

    @if (_actionMessage is not null)
    {
        <p class="success-banner">@_actionMessage</p>
    }

    @if (_errorMessage is not null)
    {
        <p class="error-banner">@_errorMessage</p>
    }

    <section class="dashboard-layout">
        <article class="panel dashboard-primary">
            <div class="panel-header">
                <div>
                    <h2>Current Status</h2>
                    <p>Summary information aligned with the classic NetTime monitor.</p>
                </div>
                <span class="support-pill">@_snapshot.Platform.SupportLevel</span>
            </div>

            <div class="fact-list">
                <div class="fact-row">
                    <span class="fact-label">Time</span>
                    <strong class="fact-value">@FormatDate(_snapshot.CurrentTime)</strong>
                </div>
                <div class="fact-row">
                    <span class="fact-label">Last Attempt</span>
                    <strong class="fact-value">@FormatDate(_snapshot.LastAttempt)</strong>
                </div>
                <div class="fact-row">
                    <span class="fact-label">Last Sync</span>
                    <strong class="fact-value">@FormatDate(_snapshot.LastSync)</strong>
                </div>
                <div class="fact-row">
                    <span class="fact-label">Sync Offset</span>
                    <strong class="fact-value">@FormatOffset(_snapshot.LastSyncOffset)</strong>
                </div>
                <div class="fact-row">
                    <span class="fact-label">Next Attempt</span>
                    <strong class="fact-value">@FormatCountdown(_snapshot.NextAttemptIn)</strong>
                </div>
                <div class="fact-row">
                    <span class="fact-label">Mode</span>
                    <strong class="fact-value">@_snapshot.ModeLabel</strong>
                </div>
            </div>

            <p class="sync-banner @GetSummaryClass(_snapshot)">@_snapshot.SummaryStatus</p>

            <div class="status-chip-grid">
                <div class="status-chip">
                    <span class="status-chip-label">Platform</span>
                    <strong class="status-chip-value">@FormatPlatform(_snapshot.Platform.Platform)</strong>
                </div>
                <div class="status-chip">
                    <span class="status-chip-label">Background Refresh</span>
                    <strong class="status-chip-value">@_snapshot.Platform.BackgroundRefreshMode</strong>
                </div>
                <div class="status-chip">
                    <span class="status-chip-label">Direct Time Adjustment</span>
                    <strong class="status-chip-value">@FormatAdjustmentAvailability(_snapshot.Platform)</strong>
                </div>
                <div class="status-chip">
                    <span class="status-chip-label">Settings Shortcut</span>
                    <strong class="status-chip-value">@FormatSettingsShortcut(_snapshot.Platform)</strong>
                </div>
            </div>
        </article>

        <div class="side-stack">
            <article class="panel panel-emphasis">
                <div class="panel-header">
                    <div>
                        <h2>Platform Notes</h2>
                        <p>@_snapshot.Platform.Summary</p>
                    </div>
                </div>
                <p class="support-copy"><strong>Mode:</strong> @_snapshot.ModeLabel</p>
                <p class="support-guidance">@_snapshot.Platform.Guidance</p>
            </article>

            <article class="panel">
                <div class="panel-header">
                    <div>
                        <h2>Last Error</h2>
                        <p>Latest sync or capability issue kept in local state.</p>
                    </div>
                </div>
                <p class="error-banner">@(_snapshot.LastError ?? "No errors recorded.")</p>
            </article>
        </div>
    </section>

    <section class="panel">
        <div class="panel-header">
            <div>
                <h2>Individual Time Servers</h2>
                <p>Each row reflects the latest persisted server state from the sync coordinator.</p>
            </div>
        </div>

        <div class="table-shell">
            <table class="server-table">
                <thead>
                    <tr>
                        <th>Server Name</th>
                        <th>Protocol</th>
                        <th>Status</th>
                        <th>Offset</th>
                        <th>Lag</th>
                        <th>Last Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var server in _snapshot.Servers)
                    {
                        <tr>
                            <td>@server.Name</td>
                            <td>@FormatProtocol(server.Protocol)</td>
                            <td>
                                <span class="state-pill @GetStateClass(server.State)">
                                    @FormatState(server.State)
                                </span>
                            </td>
                            <td>@FormatOffset(server.Offset)</td>
                            <td>@FormatLag(server.Lag)</td>
                            <td>@(server.LastError ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@code {
    private DashboardSnapshot? _snapshot;
    private DashboardSnapshot? _baseSnapshot;
    private bool _isRefreshing;
    private bool _isApplyingAdjustment;
    private bool _isOpeningSettings;
    private string? _actionMessage;
    private string? _errorMessage;
    private DateTimeOffset _baseSnapshotCapturedAt;
    private CancellationTokenSource? _clockCancellationTokenSource;
    private Task? _clockTask;

    protected override async Task OnInitializedAsync()
    {
        DashboardRefreshNotifier.RefreshRequested += RefreshFromNotificationAsync;
        StartClockLoop();
        await LoadSnapshotAsync();
    }

    private async Task ReloadAsync()
    {
        _isRefreshing = true;
        try
        {
            SetSnapshot(await Workspace.RefreshAsync(SyncTrigger.ManualUpdate));
            _actionMessage = null;
            _errorMessage = null;
        }
        catch (Exception exception)
        {
            _errorMessage = $"Sync failed unexpectedly: {exception.Message}";
        }
        finally
        {
            _isRefreshing = false;
        }
    }

    private async Task AdjustSystemTimeAsync()
    {
        _isApplyingAdjustment = true;
        try
        {
            var result = await Workspace.AdjustSystemTimeAsync();
            if (result.Succeeded)
            {
                _actionMessage = result.Message;
                _errorMessage = null;
                await LoadSnapshotAsync();
            }
            else
            {
                _actionMessage = null;
                _errorMessage = result.Message;
            }
        }
        catch (Exception exception)
        {
            _actionMessage = null;
            _errorMessage = $"System clock adjustment failed unexpectedly: {exception.Message}";
        }
        finally
        {
            _isApplyingAdjustment = false;
        }
    }

    private async Task OpenSystemTimeSettingsAsync()
    {
        _isOpeningSettings = true;
        try
        {
            var result = await Workspace.OpenSystemTimeSettingsAsync();
            if (result.Succeeded)
            {
                _actionMessage = result.Message;
                _errorMessage = null;
            }
            else
            {
                _actionMessage = null;
                _errorMessage = result.Message;
            }
        }
        catch (Exception exception)
        {
            _actionMessage = null;
            _errorMessage = $"Unable to open system settings: {exception.Message}";
        }
        finally
        {
            _isOpeningSettings = false;
        }
    }

    private async Task LoadSnapshotAsync()
    {
        try
        {
            SetSnapshot(await Workspace.GetDashboardAsync());
            _errorMessage = null;
        }
        catch (Exception exception)
        {
            _errorMessage = $"Unable to load dashboard: {exception.Message}";
        }
    }

    private void SetSnapshot(DashboardSnapshot snapshot)
    {
        _baseSnapshot = snapshot;
        _baseSnapshotCapturedAt = TimeProvider.GetLocalNow();
        _snapshot = BuildVisibleSnapshot(snapshot, _baseSnapshotCapturedAt);
    }

    private DashboardSnapshot BuildVisibleSnapshot(DashboardSnapshot snapshot, DateTimeOffset now)
    {
        var elapsed = now - _baseSnapshotCapturedAt;
        if (elapsed < TimeSpan.Zero)
        {
            elapsed = TimeSpan.Zero;
        }

        var nextAttemptIn = snapshot.NextAttemptIn - elapsed;
        if (nextAttemptIn < TimeSpan.Zero)
        {
            nextAttemptIn = TimeSpan.Zero;
        }

        return snapshot with
        {
            CurrentTime = snapshot.CurrentTime + elapsed,
            NextAttemptIn = nextAttemptIn
        };
    }

    private void StartClockLoop()
    {
        if (_clockTask is not null)
        {
            return;
        }

        _clockCancellationTokenSource = new CancellationTokenSource();
        _clockTask = RunClockLoopAsync(_clockCancellationTokenSource.Token);
    }

    private async Task RunClockLoopAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (_baseSnapshot is null)
                {
                    continue;
                }

                _snapshot = BuildVisibleSnapshot(_baseSnapshot, TimeProvider.GetLocalNow());
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private async ValueTask RefreshFromNotificationAsync()
    {
        await InvokeAsync(async () =>
        {
            await LoadSnapshotAsync();
            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        DashboardRefreshNotifier.RefreshRequested -= RefreshFromNotificationAsync;

        if (_clockCancellationTokenSource is not null)
        {
            await _clockCancellationTokenSource.CancelAsync();
            _clockCancellationTokenSource.Dispose();
        }

        if (_clockTask is not null)
        {
            await _clockTask;
        }
    }

    private static string FormatDate(DateTimeOffset? value) =>
        value?.ToLocalTime().ToString("M/d/yyyy h:mm:ss tt") ?? "Never";

    private static string FormatOffset(TimeSpan? value) =>
        value is null ? "-" : $"{value.Value.TotalMilliseconds:+0.##;-0.##;0} ms";

    private static string FormatLag(TimeSpan? value) =>
        value is null ? "-" : $"{value.Value.TotalMilliseconds:0} ms";

    private static string FormatCountdown(TimeSpan value) =>
        $"{Math.Max(0, (int)value.TotalHours)}h {value.Minutes}m {value.Seconds}s";

    private static string FormatProtocol(ServerProtocol protocol) => protocol switch
    {
        ServerProtocol.Sntp => "SNTP",
        ServerProtocol.Rfc868Tcp => "RFC868 (TCP)",
        ServerProtocol.Rfc868Udp => "RFC868 (UDP)",
        _ => "Unknown"
    };

    private static string FormatState(ServerHealthState state) => state switch
    {
        ServerHealthState.Good => "Good",
        ServerHealthState.NotUsed => "Not Used",
        ServerHealthState.Warning => "Warning",
        ServerHealthState.Error => "Error",
        _ => "Unknown"
    };

    private static string GetStateClass(ServerHealthState state) => state switch
    {
        ServerHealthState.Good => "state-good",
        ServerHealthState.NotUsed => "state-muted",
        ServerHealthState.Warning => "state-warn",
        ServerHealthState.Error => "state-error",
        _ => "state-muted"
    };

    private static string FormatPlatform(AppPlatform platform) => platform switch
    {
        AppPlatform.Windows => "Windows",
        AppPlatform.Android => "Android",
        AppPlatform.Ios => "iOS",
        _ => "Unknown"
    };

    private static string FormatAdjustmentAvailability(PlatformCapabilities platform) =>
        platform.CanAdjustDirectlyNow
            ? "Ready now"
            : platform.RequiresElevation
                ? "Needs elevation"
                : platform.SupportsDirectTimeAdjustment
                    ? "Temporarily unavailable"
                    : "Guided fallback";

    private static string FormatSettingsShortcut(PlatformCapabilities platform) =>
        platform.CanOpenSystemTimeSettings
            ? platform.SettingsActionLabel
            : "Manual steps only";

    private static string GetSummaryClass(DashboardSnapshot snapshot)
    {
        if (snapshot.SummaryStatus.Contains("failed", StringComparison.OrdinalIgnoreCase))
        {
            return "sync-banner-error";
        }

        if (snapshot.LastSync is null)
        {
            return "sync-banner-muted";
        }

        return "sync-banner-good";
    }
}
