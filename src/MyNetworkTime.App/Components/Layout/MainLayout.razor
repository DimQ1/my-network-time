@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar-shell">
        <NavMenu />
    </aside>

    <main class="workspace-shell">
        <header class="workspace-header">
            <div>
                <p class="workspace-eyebrow">Stage 1 Bootstrap</p>
                <p class="workspace-title">MAUI Blazor shell for cross-platform network time monitoring</p>
            </div>

            <div class="workspace-actions">
                <span class="workspace-chip">Windows + Android + iOS</span>
                <NavLink class="workspace-link" href="about">Roadmap</NavLink>
            </div>
        </header>

        <article class="workspace-body">
            @Body
        </article>
    </main>
</div>
